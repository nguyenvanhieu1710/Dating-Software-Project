# ========================================
# DATING SOFTWARE - BACKEND ENVIRONMENT
# ========================================

# ========================================
# SERVER CONFIGURATION
# ========================================
NODE_ENV=development
PORT=5000
HOST=localhost

# ========================================
# DATABASE CONFIGURATION
# ========================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=dating_software
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_URL=postgresql://postgres:your_password_here@localhost:5432/dating_software

# ========================================
# JWT CONFIGURATION
# ========================================
JWT_SECRET=your_super_secret_jwt_key_here_make_it_long_and_random
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_token_secret_here
JWT_REFRESH_EXPIRES_IN=30d

# ========================================
# REDIS CONFIGURATION
# ========================================
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ========================================
# SOCKET.IO CONFIGURATION
# ========================================
SOCKET_CORS_ORIGIN=http://localhost:3000
SOCKET_PING_TIMEOUT=60000
SOCKET_PING_INTERVAL=25000
SOCKET_MAX_HTTP_BUFFER_SIZE=1e6

# ========================================
# FIREBASE CONFIGURATION (Push Notifications)
# ========================================
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=your-firebase-client-email@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour Firebase Private Key Here\n-----END PRIVATE KEY-----\n"
FIREBASE_DATABASE_URL=https://your-project-id.firebaseio.com

# ========================================
# EMAIL CONFIGURATION (SMTP)
# ========================================
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM=noreply@yourdatingapp.com
EMAIL_SECURE=false

# ========================================
# FILE UPLOAD CONFIGURATION
# ========================================
UPLOAD_MAX_SIZE=10485760
UPLOAD_ALLOWED_TYPES=image/jpeg,image/png,image/gif,video/mp4,video/avi
UPLOAD_PATH=./uploads
UPLOAD_TEMP_PATH=./uploads/temp

# ========================================
# SECURITY CONFIGURATION
# ========================================
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
CORS_ORIGIN=http://localhost:3000
CORS_CREDENTIALS=true

# ========================================
# LOGGING CONFIGURATION
# ========================================
LOG_LEVEL=info
LOG_FILE=./logs/app.log
LOG_MAX_SIZE=20m
LOG_MAX_FILES=14

# ========================================
# CACHE CONFIGURATION
# ========================================
CACHE_TTL=3600
CACHE_CHECK_PERIOD=600
CACHE_MAX_KEYS=1000

# ========================================
# MESSAGE CONFIGURATION
# ========================================
MESSAGE_MAX_LENGTH=1000
MESSAGE_RATE_LIMIT=20
MESSAGE_RATE_WINDOW=60
TYPING_TIMEOUT=2000

# ========================================
# MATCH CONFIGURATION
# ========================================
MATCH_DISTANCE_RADIUS=50
MATCH_AGE_RANGE_MIN=18
MATCH_AGE_RANGE_MAX=65
MATCH_MAX_DAILY_LIKES=50

# ========================================
# FRONTEND URLs
# ========================================
FRONTEND_URL=http://localhost:3000
MOBILE_APP_URL=exp://localhost:19000
ADMIN_FRONTEND_URL=http://localhost:3001

# ========================================
# THIRD-PARTY SERVICES
# ========================================

# Google Maps API
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# AWS S3 (for file storage)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-dating-app-bucket

# Cloudinary (alternative to S3)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ========================================
# MONITORING & ANALYTICS
# ========================================
SENTRY_DSN=your_sentry_dsn_here
NEW_RELIC_LICENSE_KEY=your_new_relic_key_here
NEW_RELIC_APP_NAME=DatingApp-Backend

# ========================================
# DEVELOPMENT TOOLS
# ========================================
DEBUG=socket.io:*,app:*
NODEMON_IGNORE=uploads/*,logs/*,node_modules/*
NODEMON_DELAY=1000

# ========================================
# TESTING CONFIGURATION
# ========================================
TEST_DB_NAME=dating_software_test
TEST_REDIS_DB=1
JEST_TIMEOUT=10000

# ========================================
# PRODUCTION OVERRIDES
# ========================================
# Uncomment and modify these for production
# NODE_ENV=production
# PORT=80
# HOST=0.0.0.0
# CORS_ORIGIN=https://yourdomain.com
# FRONTEND_URL=https://yourdomain.com
# LOG_LEVEL=error
# REDIS_URL=redis://your-redis-server:6379
# DB_URL=postgresql://user:pass@your-db-server:5432/dating_software 